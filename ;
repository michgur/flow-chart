import { Panel } from "@xyflow/react";
import type { GoalWithoutId } from "../data-model";
import type { FlowSelection } from "../hooks/use-flow-selection";
import { getGoal, getTransition } from "../script-actions";
import { GoalInspector } from "./GoalInspector";
import { TransitionInspector } from "./TransitionInspector";

type FlowInspectorProps = {
  selection: FlowSelection;
};

export function FlowInspector({ selection }: FlowInspectorProps) {
  if (selection?.kind !== 'goal' && selection?.kind !== 'transition') return null
  const selectedGoal =
    selection?.kind === "goal" ? (getGoal(model, selection.id) ?? null) : null;
  const selectedTransition =
    selection?.kind === "transition"
      ? (getTransition(model, selection.id) ?? null)
      : null;

  const selectedGoalValue: GoalWithoutId | null = selectedGoal
    ? {
        name: selectedGoal.name,
        messages: selectedGoal.messages,
        transitions: selectedGoal.transitions,
      }
    : null;

  return (
    <Panel
      position="center-right"
      className="inset-3! inset-s-auto! m-0! flex w-80 space-y-3 overflow-y-auto rounded-md border border-slate-300 bg-slate-50"
    >
      {selection?.kind === "goal" ? (
        <GoalInspector
          value={selectedGoalValue}
          onChange={(nextGoal) => onChangeGoal(selectedGoal.id, nextGoal)}
        />
      ) : null}

      {selection?.kind === "transition" &&
      selectedTransition &&
      selectedTransition ? (
        <TransitionInspector
          id={selection.id}
          value={selectedTransition}
          onChange={(nextTransition) =>
            onChangeTransition(selection.id, nextTransition)
          }
        />
      ) : null}
    </Panel>
  );
}
